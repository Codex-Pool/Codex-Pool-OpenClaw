{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "strict": true,
    "noEmitOnError": true,
    "outDir": "./dist",
    "rootDir": ".",
    "declaration": true,
    "declarationMap": true,
    "allowJs": true,
    "checkJs": false,
    "sourceMap": true,
    "isolatedModules": true,
    "skipLibCheck": true,
    "types": ["node"],
    "resolveJsonModule": true,
    "verbatimModuleSyntax": true
  },
  "include": ["index.ts", "src/**/*.ts", "src/**/*.js"],
  "exclude": ["coverage", "dist", "node_modules", "tests"]
}
